# DaShengOS .gitignore

# === 数据库 🔴 绝对不能提交 ===
*.db
*.db-shm
*.db-wal
*.db.corrupt.bak
*.sqlite
*.sqlite3

# === 备份 🔴 绝对不能提交 ===
backups/

# === 敏感配置 🔴 绝对不能提交 ===
.env
.env.*
!.env.example
.codex-protect
.codex-protect-hash
secrets/
*.pem
*.key
*.p12
credentials.json

# === Vendors ===
vendors/

# === Logs ===
.logs/
*.log
logs/

# === Node.js ===
**/node_modules/
**/.next/
**/out/
**/dist/

# === Python ===
**/.venv/
**/venv/
**/__pycache__/
**/*.pyc
**/*.pyo
**/.pytest_cache/

# === IDE / OS ===
.DS_Store
.vscode/
.idea/
*.swp

# === pnpm ===
.pnpm-store/

# === Generated ===
health-check-report-*.html
.env.persist
zvec/

# === macOS ===
*.icloud
