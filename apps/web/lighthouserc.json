{
  "ci": {
    "collect": {
      "startServerCommand": "pnpm preview",
      "startServerReadyPattern": "Local:",
      "startServerReadyTimeout": 30000,
      "url": [
        "http://127.0.0.1:3000/",
        "http://127.0.0.1:3000/login",
        "http://127.0.0.1:3000/agents",
        "http://127.0.0.1:3000/mcp",
        "http://127.0.0.1:3000/files",
        "http://127.0.0.1:3000/settings",
        "http://127.0.0.1:3000/chats/c-001",
        "http://127.0.0.1:3000/error/404"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "skipAudits": ["uses-http2", "is-on-https", "valid-source-maps", "uses-rel-preconnect"]
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],
        "categories:seo": ["warn", { "minScore": 0.85 }],

        "color-contrast": "error",
        "image-alt": "error",
        "label-content-name-mismatch": "error",
        "label": "error",
        "link-name": "error",
        "button-name": "error",
        "aria-allowed-attr": "error",
        "aria-required-attr": "error",
        "aria-valid-attr": "error",
        "aria-valid-attr-value": "error",
        "html-has-lang": "error",
        "html-lang-valid": "error",
        "meta-viewport": "error",
        "document-title": "error",
        "meta-description": "error",
        "robots-txt": "error"
      }
    }
  }
}

