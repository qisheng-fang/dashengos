# DaShengOS v0.3 生产环境配置模板
# 复制此文件到 packages/backend/.env 并按需修改
# ⚠️ 此文件不进 git (已在 .gitignore)

# ============================================
# 环境
# ============================================
NODE_ENV=production

# ============================================
# 后端
# ============================================
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# ============================================
# 数据库 (SQLite 默认 / PostgreSQL 生产)
# ============================================
# SQLite (单机/开发):
DATABASE_TYPE=sqlite
DATABASE_URL=file:./data/dasheng.db

# PostgreSQL (生产/多实例):
# DATABASE_TYPE=postgres
# DATABASE_URL=postgres://user:password@host:5432/dasheng

# ============================================
# Redis (可选, 缓存 + 会话共享)
# ============================================
# REDIS_URL=redis://127.0.0.1:6379/0

# ============================================
# JWT (⚠️ 生产必须改! >=32 字符)
# ============================================
DASHENG_JWT_SECRET=REPLACE_ME_MIN_32_CHARACTERS_LONG_RANDOM_STRING
# DASHENG_JWT_ACCESS_TTL_SEC=900
# DASHENG_JWT_REFRESH_TTL_SEC=604800

# ============================================
# CORS / 安全 (生产必须配)
# ============================================
CORS_ORIGINS=https://dasheng.example.com,https://admin.example.com
# CSRF_ENABLED=true
# CSP_ENABLED=true
# DASHENG_STRICT_SECURITY=true

# ============================================
# Cookie 加密密钥 (生产必配, >=32 字符)
# ============================================
COOKIE_ENCRYPTION_KEY=REPLACE_ME_MIN_32_CHARACTERS_LONG_RANDOM_STRING

# ============================================
# LLM Provider API Keys
# ============================================
# SILICONFLOW_API_KEY=sk-...
# DEEPSEEK_API_KEY=sk-...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-...

# ============================================
# 审计日志 HMAC 密钥 (生产必配, >=32 字符)
# ============================================
AUDIT_LOG_HMAC_SECRET=REPLACE_ME_MIN_32_CHARACTERS_LONG_RANDOM_STRING

# ============================================
# Stripe (支付)
# ============================================
# DASHENG_STRIPE_WEBHOOK_SECRET=whsec_...
# DASHENG_STRIPE_MOCK_MODE=false
# DASHENG_STRIPE_PRICE_PRO=price_xxx
# DASHENG_STRIPE_PRICE_ENTERPRISE=price_yyy

# ============================================
# 观察
# ============================================
LOG_LEVEL=info
# METRICS_ENABLED=true
# METRICS_PORT=9090
