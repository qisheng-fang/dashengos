    "@fastify/websocket": "^11.0.2",
    "@types/node-cron": "^3.0.11",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.30.1",
    "drizzle-orm": "^0.38.3",
