# packages/backend/.env.example · v0.3 B 方案 (Track D.1 加 SiliconFlow/DeepSeek provider, 2026-06-15)
# 强约束: 127.0.0.1 绑定 · JWT 必填 · API key 走 Keychain (Phase 2 stub)
# 复制为 packages/backend/.env 后填入实际值; .env 不要提交到 git

# ============================================================
# Backend
# ============================================================
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DEBUG=true
APP_SECRET_KEY=change-me-in-production-please-use-random-32-bytes
APP_LOG_LEVEL=INFO

# ============================================================
# Database
# ============================================================
DATABASE_URL=sqlite:///./data/dasheng.db
SQLALCHEMY_ECHO=false

# ============================================================
# LLM · Track D.1 (2026-06-15) 3 provider 切换
# ============================================================
# Ollama 本地 (无需 key, 13s cold / 1s warm, 1.9GB RAM)
LLM_PROVIDER=ollama
OLLAMA_HOST=http://127.0.0.1:11434
DEFAULT_MODEL=ollama:qwen2.5:7b

# SiliconFlow (OpenAI 兼容, 老板之前用 Qwen2.5-72B) — Track D.1 推荐
# 注册: https://cloud.siliconflow.cn/account/ak
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_DEFAULT_MODEL=Qwen/Qwen2.5-72B-Instruct
SILICONFLOW_TIMEOUT_SEC=60

# DeepSeek (OpenAI 兼容, 备选)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ============================================================
# Hermes-V2 (Track A · agent/ Python, 旧 DaShengOS 引擎)
# ============================================================
HERMES_V2_MAX_WORKERS=20
HERMES_V2_MAX_RETRIES=2
HERMES_V2_LLM_CACHE_TTL=300
HERMES_V2_LLM_CACHE_SIZE=1000
HERMES_V2_CONTEXT_COMPRESS_THRESHOLD=8000

# ============================================================
# Track B · 5 worker 端点 (旧 DaShengOS worker 跑在宿主机)
# ============================================================
SAU_BRIDGE_URL=http://127.0.0.1:9109
DOUYIN_BRIDGE_URL=http://127.0.0.1:9112
WECHAT_MP_URL=http://127.0.0.1:9113
VIDEO_PARSER_URL=http://127.0.0.1:9111
PIXELLE_BRIDGE_URL=http://127.0.0.1:9108

# ============================================================
# JWT
# ============================================================
DASHENG_JWT_SECRET=dev-only-secret-please-replace-in-prod-32chars
DASHENG_JWT_ACCESS_TTL_SEC=900
DASHENG_JWT_REFRESH_TTL_SEC=604800

# ============================================================
# Rate Limit
# ============================================================
RATE_LIMIT_PER_MINUTE=60

# ============================================================
# Security
# ============================================================
DASHENG_STRICT_SECURITY=false
DASHENG_INJECTION_SCAN_ENABLED=true

# ============================================================
# Audit
# ============================================================
AUDIT_LOG_RETENTION_DAYS=365
AUDIT_LOG_HMAC_SECRET=dev-only-audit-hmac-secret-32chars-min-aaaaa

# ============================================================
# Observability
# ============================================================
LOG_LEVEL=info
METRICS_ENABLED=true
METRICS_PORT=9090

# ============================================================
# Phase 7.5: Stripe webhook (Track C+)
# ============================================================
DASHENG_STRIPE_WEBHOOK_SECRET=
DASHENG_STRIPE_MOCK_MODE=true
DASHENG_STRIPE_PRICE_PRO=price_pro_dev
DASHENG_STRIPE_PRICE_ENTERPRISE=price_enterprise_dev

# ============================================================
# DeerFlow
# ============================================================
DEERFLOW_ENABLED=false
DEERFLOW_SOCKET_PATH=/tmp/dasheng/deerflow.sock

# ============================================================
# Track D4 (2026-06-18) · 4 平台 OAuth 凭证
#   公众号/飞书: 去开发者后台创建应用拿 appid/secret, 配回调域名
#   视频号: 复用公众号 appid, 无需独立配
#   Shopify: 在 Shopify 后台 Settings → Develop apps 创建 Custom App 拿 admin token
# ============================================================

# 微信公众号 (https://mp.weixin.qq.com/ → 开发 → 基本配置)
#   回调域名: 公众号后台 → 设置 → 公众号设置 → 功能设置 → 网页授权域名 (不带 http://)
WECHAT_MP_APPID=
WECHAT_MP_SECRET=
WECHAT_MP_REDIRECT_URI=http://127.0.0.1:3000/oauth/callback/wechat_mp
#  scope: snsapi_base (静默, 只拿 openid) | snsapi_userinfo (拿昵称头像, 需关注)
WECHAT_MP_SCOPE=snsapi_base

# 飞书 (https://open.feishu.cn/app)
#   权限: contact:user.id:readonly (必勾)
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=http://127.0.0.1:3000/oauth/callback/feishu

# Shopify 爱尤趣独立站 (无需预配, 老板在 OAuthManager 页面填 token)
#   SHOPIFY_SHOP=aiyouqu.myshopify.com
#   SHOPIFY_ACCESS_TOKEN=shpat_xxx  (在 Custom App 安装时拿)
