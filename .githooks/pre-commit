#!/bin/bash
# DaShengOS v6.1 — Pre-commit 保护钩子
# 防止关键文件被意外提交修改

PROTECTED_FILES=(
  "packages/backend/src/core/harness/system-prompt.ts"
  "packages/backend/src/core/system-prompt-config.ts"
  ".env"
  "packages/backend/data/dasheng.db"
  "start.sh"
  "restart.sh"
)

STAGED=$(git diff --cached --name-only)

for pf in "${PROTECTED_FILES[@]}"; do
  if echo "$STAGED" | grep -qF "$pf"; then
    echo "🔴 禁止提交受保护文件: $pf"
    echo "   如需修改，请先与项目负责人确认"
    echo "   然后运行: git commit --no-verify 强制提交（会记录审计日志）"
    exit 1
  fi
done

# Check system-prompt.ts integrity (hash check)
if [ -f "packages/backend/src/core/harness/system-prompt.ts" ]; then
  HASH=$(shasum -a 256 "packages/backend/src/core/harness/system-prompt.ts" | cut -d' ' -f1)
  HASH_FILE=".codex-protect-hash"
  if [ -f "$HASH_FILE" ]; then
    STORED=$(cat "$HASH_FILE")
    if [ "$HASH" != "$STORED" ] && echo "$STAGED" | grep -q "system-prompt"; then
      echo "⚠️  system-prompt.ts 哈希不匹配 — 可能被AI修改"
      echo "   当前: $HASH"
      echo "   存储: $STORED"
      echo "   如果确认修改，运行: shasum -a 256 packages/backend/src/core/harness/system-prompt.ts > .codex-protect-hash"
    fi
  fi
fi

exit 0
